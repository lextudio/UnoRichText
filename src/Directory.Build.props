<Project>
  <PropertyGroup>
    <UnoUIDisableLongPathWarning>true</UnoUIDisableLongPathWarning>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <ManagePackageVersionsCentrally>true</ManagePackageVersionsCentrally>
    <EnableRichTextBox Condition="'$(EnableRichTextBox)' == ''">false</EnableRichTextBox>
    <DefineConstants Condition="'$(EnableRichTextBox)' == 'true'">$(DefineConstants);RICHTEXTBOX</DefineConstants>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="GitVersion.MsBuild" PrivateAssets="All" />
  </ItemGroup>
</Project>
